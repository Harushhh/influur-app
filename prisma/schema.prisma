generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Vector extension temporarily removed for local development
}

enum Role {
  BRAND
  CREATOR
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum CampaignStatus {
  DRAFT
  PUBLISHED
  PAUSED
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}

enum OptInStatus {
  PENDING
  INTERESTED
  DECLINED
  UNLOCKED
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  username   String?  @unique
  avatarUrl  String?
  role       Role     @default(CREATOR)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscription      Subscription?
  influencerProfile InfluencerProfile?

  oauthTokens   OAuthToken[]
  searchHistory SearchHistory[]

  campaigns        Campaign[]        @relation("BrandCampaigns")
  savedInfluencers SavedInfluencer[] @relation("BrandSaves")

  applications  Application[]     @relation("CreatorApplications")
  savedByBrands SavedInfluencer[] @relation("InfluencerSaved")

  @@index([role])
  @@index([email])
}

model Subscription {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier              SubscriptionTier @default(FREE)
  stripeCustomerId  String?
  stripePriceId     String?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean          @default(false)
  unlocksRemaining  Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model InfluencerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio      String?  @db.Text
  location String?
  niche    String[]

  totalAudience     Int    @default(0)
  avgEngagementRate Float  @default(0.0)
  authenticityScore Float?

  igHandle     String? @unique
  igFollowers  Int     @default(0)
  igEngagement Float   @default(0.0)
  igRateCard   Float?

  ttHandle     String? @unique
  ttFollowers  Int     @default(0)
  ttEngagement Float   @default(0.0)
  ttRateCard   Float?

  ytHandle      String? @unique
  ytSubscribers Int     @default(0)
  ytAvgViews    Int     @default(0)
  ytRateCard    Float?

  audienceData  Json?
  growthHistory Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([totalAudience(sort: Desc)])
  @@index([avgEngagementRate(sort: Desc)])
}

model CreatorDNA {
  id         String  @id @default(cuid())
  username   String  @unique
  name       String
  avatar     String?
  bio        String? @db.Text
  followers  Int     @default(0)
  engagement Float   @default(0.0)
  location   String?
  category   String?
  realReach  Int     @default(0)
  cpm        Float   @default(0.0)
  isVerified Boolean @default(false)
  hasEmail   Boolean @default(false)

  advancedData Json?
  recentPosts  Json?
  metadata     Json?

  // AI Lookalike Vector mapping (Temporarily paused for local DB compatibility)
  // embedding      Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([followers(sort: Desc)])
  @@index([engagement(sort: Desc)])
  @@index([category])
  @@index([location])
}

model Campaign {
  id      String @id @default(cuid())
  brandId String
  brand   User   @relation("BrandCampaigns", fields: [brandId], references: [id], onDelete: Cascade)

  title        String
  description  String   @db.Text
  deliverables String[]
  targetNiche  String[]
  minFollowers Int      @default(0)
  budgetRange  String?

  status             CampaignStatus @default(DRAFT)
  applicationDealine DateTime?

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
}

model Application {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation("CreatorApplications", fields: [creatorId], references: [id], onDelete: Cascade)

  coverLetter  String            @db.Text
  proposedRate Float?
  status       ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, creatorId])
  @@index([creatorId])
  @@index([status])
}

model SavedInfluencer {
  id String @id @default(cuid())

  brandId String?
  brand   User?   @relation("BrandSaves", fields: [brandId], references: [id], onDelete: Cascade)

  influencerId String?
  influencer   User?   @relation("InfluencerSaved", fields: [influencerId], references: [id], onDelete: Cascade)

  externalUsername String?
  externalData     Json?

  optInStatus OptInStatus @default(PENDING)
  notes       String?     @db.Text
  listName    String      @default("Default List")

  savedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([optInStatus])
  @@index([brandId])
  @@index([listName])
}

model SearchHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query       String
  filtersUsed Json?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model OAuthToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  accessToken  String
  refreshToken String?
  tokenType    String    @default("Bearer")
  scope        String[]
  expiresAt    DateTime?
  accountId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([provider])
}
